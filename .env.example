# =============================================
# 阿里云账号信息
# 控制台右上角头像 -> AccessKey 管理
# =============================================
ACCESS_KEY_ID=你的AccessKeyId
ACCESS_KEY_SECRET=你的AccessKeySecret

# =============================================
# 阿里云账号 UID
# 控制台右上角头像 -> 安全设置 -> 账号ID
# 或者访问https://account.console.aliyun.com/,页面上就能看到账号 ID（UID），是一串数字
# =============================================
ALIYUN_UID=你的阿里云账号UID

# =============================================
# IoT 平台配置
# =============================================
IOT_REGION=cn-shanghai
CONSUMER_GROUP_ID=trace_consumer_group

# =============================================
# 可选配置
# =============================================
# 日志级别 debug / info / error
LOG_LEVEL=info
# 每收到多少帧打印一次汇总（默认100）
PRINT_INTERVAL=100

# 若环境缺少完整根证书链可临时设为 true
# AMQP_INSECURE_TLS=true
